# OpenRouter API (for LLM — contact extraction + script generation)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs API (for TTS voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Twilio (for outbound phone calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email IMAP settings (for inbound email polling)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Database
DATABASE_URL=./data/outreach.db

# App
APP_BASE_URL=http://localhost:3001
PORT=3001
